}

function sortedChampionsForRole(role = "") {
  return [...state.indexes.champions].sort((a, b) => {
    const roleDiff = championRoleSample(b, role) - championRoleSample(a, role);
    if (roleDiff !== 0) return roleDiff;
    return a.localeCompare(b);
  });
}

